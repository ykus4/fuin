# Copy this file to .env and fill in your values.
# .env is git-ignored and must never be committed.

# -----------------------------------------------------------------------
# Server auth (required)
# -----------------------------------------------------------------------
FUIN_API_KEY=your-secret-api-key-here

# -----------------------------------------------------------------------
# Signing keystore (optional)
# If not set, a temporary debug keystore is generated automatically.
# Use a real keystore for production / release builds.
# -----------------------------------------------------------------------
# FUIN_KEYSTORE_PATH=/path/to/release.keystore
# FUIN_KEYSTORE_ALIAS=fuin
# FUIN_KEYSTORE_STORE_PASS=your-store-password
# FUIN_KEYSTORE_KEY_PASS=your-key-password

# -----------------------------------------------------------------------
# Storage (optional — defaults shown)
# -----------------------------------------------------------------------
# FUIN_PACKED_DIR=./packed_apks
# FUIN_DATABASE_URL=sqlite:///./fuin.db

# -----------------------------------------------------------------------
# Key server URL (used by packer CLI when --server-url is not passed)
# -----------------------------------------------------------------------
# FUIN_SERVER_URL=https://your-key-server.example.com
